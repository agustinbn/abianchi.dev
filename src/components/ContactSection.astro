---
type LinkIcon = "link" | "github" | "external";

export type ContactLink = {
	title: string;
	href: string;
	description: string;
	icon?: LinkIcon;
};

export type Props = {
	links?: ContactLink[];
};

const { links = [] } = Astro.props;

const defaultLinks: ContactLink[] = [
	{
		title: "GitHub",
		href: "https://github.com/agustinbn",
		description: "Check out my projects and code.",
		icon: "github",
	},
	{
		title: "Source Code for this website",
		href: "https://github.com/agustinbn/abianchi.dev",
		description: "Help me improve this website.",
		icon: "link",
	},
	{
		title: "LinkedIn",
		href: "https://www.linkedin.com/in/agusbianchi/",
		description: "Connect with me on LinkedIn.",
		icon: "link",
	},
	{
		title: "X",
		href: "https://x.com/abianchi06",
		description: "Follow me on X.",
		icon: "link",
	},
];

const finalLinks = links.length > 0 ? links : defaultLinks;

const iconClass =
	"inline-block h-4 w-4 text-[var(--console-muted)] shrink-0 translate-y-[1px]";
---

<div class="grid gap-3 sm:grid-cols-2">
	{
		finalLinks.map((l) => (
			<a class="card" href={l.href} target="_blank" rel="noreferrer">
				<div class="flex items-start justify-between gap-3">
					<div class="min-w-0">
						<p class="title">
							<span class="select-none text-[var(--console-muted)]" aria-hidden="true"
								>$</span
							>{" "}
							<span class="text-[var(--console-bright)]">{l.title}</span>
						</p>
						<p class="desc">{l.description}</p>
					</div>
					<div aria-hidden="true">
						{l.icon === "github" ? (
							<svg class={iconClass} viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 2C6.477 2 2 6.558 2 12.174c0 4.49 2.865 8.298 6.839 9.643.5.095.682-.22.682-.49 0-.24-.009-.874-.014-1.715-2.782.62-3.369-1.364-3.369-1.364-.454-1.174-1.11-1.486-1.11-1.486-.908-.636.069-.623.069-.623 1.003.072 1.53 1.05 1.53 1.05.892 1.557 2.341 1.107 2.91.846.09-.664.35-1.108.636-1.362-2.22-.26-4.555-1.134-4.555-5.048 0-1.116.389-2.03 1.025-2.746-.103-.26-.444-1.305.098-2.72 0 0 .84-.274 2.75 1.05A9.31 9.31 0 0 1 12 6.844a9.3 9.3 0 0 1 2.504.35c1.909-1.324 2.748-1.05 2.748-1.05.543 1.415.202 2.46.1 2.72.637.716 1.023 1.63 1.023 2.746 0 3.924-2.338 4.785-4.566 5.04.36.315.68.935.68 1.885 0 1.36-.012 2.456-.012 2.79 0 .272.18.589.688.488C19.138 20.468 22 16.66 22 12.174 22 6.558 17.523 2 12 2z" />
							</svg>
						) : l.icon === "external" ? (
							<svg
								class={iconClass}
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
							>
								<path d="M14 3h7v7" />
								<path d="M10 14L21 3" />
								<path d="M21 14v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6" />
							</svg>
						) : l.icon === "link" ? (
							<svg
								class={iconClass}
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
							>
								<path d="M10 13a5 5 0 0 1 0-7l1.5-1.5a5 5 0 0 1 7 7L17 13" />
								<path d="M14 11a5 5 0 0 1 0 7L12.5 19.5a5 5 0 0 1-7-7L7 11" />
							</svg>
						) : null}
					</div>
				</div>
			</a>
		))
	}
</div>

<style>
	.card {
		display: block;
		border: 1px solid var(--console-border);
		border-radius: 14px;
		padding: 14px 14px;
		text-decoration: none;
		background: rgba(196, 232, 216, 0.02);
		transition:
			border-color 160ms ease,
			transform 160ms ease,
			background-color 160ms ease;
	}

	.card:hover {
		border-color: color-mix(
			in oklab,
			var(--console-accent) 55%,
			var(--console-border)
		);
		background: rgba(46, 207, 156, 0.06);
		transform: translateY(-1px);
	}

	.card:focus-visible {
		outline: 2px solid var(--console-accent);
		outline-offset: 3px;
	}

	.title {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.3;
	}

	.desc {
		margin: 6px 0 0;
		color: var(--console-text);
		opacity: 0.9;
		line-height: 1.55;
		white-space: pre-wrap;
	}

	@media (prefers-reduced-motion: reduce) {
		.card {
			transition: none;
		}

		.card:hover {
			transform: none;
		}
	}
</style>
