---
export type Props = {
	id?: string;
	title: string;
	command: string;
};

const { id, title, command } = Astro.props;
---

<section id={id} class="mx-auto max-w-4xl px-4 py-20 sm:px-6">
	<p class="text-sm text-[var(--console-muted)]">
		<span class="select-none" aria-hidden="true">$</span> {command}
	</p>
	<h2 class="mt-3 text-2xl font-semibold tracking-tight text-[var(--console-bright)]">
		{title}
	</h2>
	<div class="mt-5">
		<slot />
	</div>
</section>
