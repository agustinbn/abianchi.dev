---
const links = [
	{ href: "#", label: "home" },
	{ href: "#work", label: "work" },
	{ href: "#contact", label: "contact" },
];
---

<div class="sticky top-0 z-50 px-4 pt-4 sm:px-6">
	<header class="console-bar mx-auto max-w-4xl" role="banner">
		<div
			class="flex items-center justify-between gap-4 px-4 py-3 font-mono text-sm sm:px-6"
		>
			<a
				href="/"
				class="flex items-center gap-2 text-[var(--console-bright)] no-underline"
			>
				<span
					class="select-none text-[var(--console-accent)]"
					aria-hidden="true">$</span
				>
				<span class="tracking-tight">
					<span class="text-[var(--console-muted)]">~/</span>abianchi.dev<span
						class="console-bar__cursor text-[var(--console-bright)]"
						aria-hidden="true">▌</span
					>
				</span>
			</a>
			<nav
				class="flex flex-wrap items-center gap-4 sm:gap-5"
				aria-label="Primary"
			>
				{
					links.map((link) => (
						<a
							href={link.href}
							class="text-[var(--console-muted)] no-underline hover:text-[var(--console-text)]"
						>
							./{link.label}
						</a>
					))
				}
			</nav>
		</div>
	</header>
</div>

<style>
	.console-bar {
		background: var(--console-bg);
	}

	.console-bar__cursor {
		margin-left: 1px;
		display: inline-block;
		font-weight: 300;
		animation: console-bar-cursor 1.05s step-end infinite;
		vertical-align: -0.05em;
	}

	@keyframes console-bar-cursor {
		0%,
		49% {
			opacity: 1;
		}
		50%,
		100% {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.console-bar__cursor {
			animation: none;
			opacity: 1;
		}
	}
</style>
